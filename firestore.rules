rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow any authenticated session (including anonymous) to read/write.
      // The app signs in anonymously before every Firestore operation so
      // request.auth will never be null for legitimate app traffic.
      allow read, write: if request.auth != null;
    }

    // Lock down everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
